{
    "name": "myfeed",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "scripts": {
        "start": "expo start",
        "start-tunnel": "expo start --tunnel",
        "reset-project": "node ./scripts/reset-project.js",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "lint-check": "expo lint",
        "lint-fix": "expo lint --fix",
        "prettier-check": "yarn prettier --check \"app/**/*.+(js|jsx|mjs|cjs|ts|tsx|json)\"",
        "prettier-fix": "yarn prettier --write \"app/**/*.+(js|jsx|mjs|cjs|ts|tsx|json)\"",
        "compile": "yarn tsc",
        "postinstall": "yarn husky",
        "pre-commit": "if [ -e .git ]; then yarn run lint-check && yarn lint-staged && yarn run compile; else echo 'pre-commit was not executed cause cannot find .git'; fi",
        "lint": "expo lint"
    },
    "lint-staged": {
        "**/*.{ts,mts,cts,tsx,js,mjs,cjs,jsx,md}": [
            "yarn run lint-fix",
            "yarn run prettier-fix"
        ]
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@react-navigation/bottom-tabs": "^7.4.0",
        "@react-navigation/elements": "^2.6.3",
        "@react-navigation/native": "^7.1.8",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "axios": "^1.14.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "expo": "~54.0.33",
        "expo-constants": "~18.0.13",
        "expo-font": "~14.0.11",
        "expo-haptics": "~15.0.8",
        "expo-image": "~3.0.11",
        "expo-linking": "~8.0.11",
        "expo-router": "~6.0.23",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-symbols": "~1.0.8",
        "expo-system-ui": "~6.0.9",
        "expo-web-browser": "~15.0.10",
        "globals": "^17.4.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-web": "~0.21.0",
        "react-native-worklets": "0.5.1",
        "typescript-eslint": "^8.57.2",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@types/react": "~19.1.0",
        "commitlint": "^20.4.4",
        "conventional-changelog-conventionalcommits": "^9.3.0",
        "eslint": "^9.25.0",
        "eslint-config-expo": "~10.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2"
    },
    "private": true
}
